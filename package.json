{
  "name": "openclaw-on-nixos",
  "private": true,
  "version": "0.1.0",
  "description": "OpenClaw on NixOS monorepo skeleton",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:up": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-up.ps1",
    "dev:up:unix": "bash ./nix/scripts/dev-up.sh",
    "dev:check": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-check.ps1",
    "dev:check:unix": "bash ./nix/scripts/dev-check.sh",
    "dev:down": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-down.ps1",
    "dev:down:unix": "bash ./nix/scripts/dev-down.sh",
    "dev:state-check": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-state-settling-check.ps1",
    "dev:state-check:unix": "bash ./nix/scripts/dev-state-settling-check.sh",
    "dev:body-config-check:unix": "bash ./nix/scripts/dev-body-config-check.sh",
    "dev:command-capture-check": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-command-capture-check.ps1",
    "dev:command-capture-check:unix": "bash ./nix/scripts/dev-command-capture-check.sh",
    "dev:task-workbench-check:unix": "bash ./nix/scripts/dev-task-workbench-check.sh",
    "dev:task-executor-check:unix": "bash ./nix/scripts/dev-task-executor-check.sh",
    "dev:persistence-check:unix": "bash ./nix/scripts/dev-persistence-check.sh",
    "dev:planner-check:unix": "bash ./nix/scripts/dev-planner-check.sh",
    "dev:operator-loop-check:unix": "bash ./nix/scripts/dev-operator-loop-check.sh",
    "dev:operator-control-check:unix": "bash ./nix/scripts/dev-operator-control-check.sh",
    "dev:policy-check:unix": "bash ./nix/scripts/dev-policy-check.sh",
    "dev:sovereign-body-policy-check:unix": "bash ./nix/scripts/dev-sovereign-body-policy-check.sh",
    "dev:sovereign-command-execute-check:unix": "bash ./nix/scripts/dev-sovereign-command-execute-check.sh",
    "dev:sovereign-command-chain-check:unix": "bash ./nix/scripts/dev-sovereign-command-chain-check.sh",
    "dev:sovereign-command-branch-check:unix": "bash ./nix/scripts/dev-sovereign-command-branch-check.sh",
    "dev:sovereign-command-recovery-check:unix": "bash ./nix/scripts/dev-sovereign-command-recovery-check.sh",
    "dev:sovereign-command-ledger-check:unix": "bash ./nix/scripts/dev-sovereign-command-ledger-check.sh",
    "dev:sovereign-filesystem-write-check:unix": "bash ./nix/scripts/dev-sovereign-filesystem-write-check.sh",
    "dev:sovereign-filesystem-workspace-check:unix": "bash ./nix/scripts/dev-sovereign-filesystem-workspace-check.sh",
    "dev:sovereign-filesystem-append-check:unix": "bash ./nix/scripts/dev-sovereign-filesystem-append-check.sh",
    "dev:sovereign-filesystem-ledger-check:unix": "bash ./nix/scripts/dev-sovereign-filesystem-ledger-check.sh",
    "dev:sovereign-filesystem-read-text-check:unix": "bash ./nix/scripts/dev-sovereign-filesystem-read-text-check.sh",
    "dev:sovereign-filesystem-read-ledger-check:unix": "bash ./nix/scripts/dev-sovereign-filesystem-read-ledger-check.sh",
    "dev:approval-check:unix": "bash ./nix/scripts/dev-approval-check.sh",
    "dev:capability-check:unix": "bash ./nix/scripts/dev-capability-check.sh",
    "dev:capability-planner-check:unix": "bash ./nix/scripts/dev-capability-planner-check.sh",
    "dev:capability-invoke-check:unix": "bash ./nix/scripts/dev-capability-invoke-check.sh",
    "dev:capability-history-check:unix": "bash ./nix/scripts/dev-capability-history-check.sh",
    "dev:capability-operator-check:unix": "bash ./nix/scripts/dev-capability-operator-check.sh",
    "dev:capability-approval-operator-check:unix": "bash ./nix/scripts/dev-capability-approval-operator-check.sh",
    "dev:event-audit-check:unix": "bash ./nix/scripts/dev-event-audit-check.sh",
    "dev:system-capability-check:unix": "bash ./nix/scripts/dev-system-capability-check.sh",
    "dev:system-sense-check:unix": "bash ./nix/scripts/dev-system-sense-check.sh",
    "dev:system-heal-check:unix": "bash ./nix/scripts/dev-system-heal-check.sh",
    "dev:openclaw-workspace-detect-check:unix": "bash ./nix/scripts/dev-openclaw-workspace-detect-check.sh",
    "dev:openclaw-workspace-command-proposals-check:unix": "bash ./nix/scripts/dev-openclaw-workspace-command-proposals-check.sh",
    "dev:openclaw-workspace-command-plan-check:unix": "bash ./nix/scripts/dev-openclaw-workspace-command-plan-check.sh",
    "dev:observer-capability-plan-check:unix": "bash ./nix/scripts/dev-observer-capability-plan-check.sh",
    "dev:observer-capability-invoke-check:unix": "bash ./nix/scripts/dev-observer-capability-invoke-check.sh",
    "dev:observer-capability-history-check:unix": "bash ./nix/scripts/dev-observer-capability-history-check.sh",
    "dev:observer-command-transcript-check:unix": "bash ./nix/scripts/dev-observer-command-transcript-check.sh",
    "dev:observer-command-ledger-check:unix": "bash ./nix/scripts/dev-observer-command-ledger-check.sh",
    "dev:observer-filesystem-ledger-check:unix": "bash ./nix/scripts/dev-observer-filesystem-ledger-check.sh",
    "dev:observer-filesystem-read-ledger-check:unix": "bash ./nix/scripts/dev-observer-filesystem-read-ledger-check.sh",
    "dev:observer-workspace-detect-check:unix": "bash ./nix/scripts/dev-observer-workspace-detect-check.sh",
    "dev:observer-workspace-command-proposals-check:unix": "bash ./nix/scripts/dev-observer-workspace-command-proposals-check.sh",
    "dev:observer-operator-check:unix": "bash ./nix/scripts/dev-observer-operator-check.sh",
    "dev:milestone-check:unix": "bash ./nix/scripts/dev-milestone-check.sh"
  }
}
