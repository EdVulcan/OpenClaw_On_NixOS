{
  "name": "openclaw-on-nixos",
  "private": true,
  "version": "0.1.0",
  "description": "OpenClaw on NixOS monorepo skeleton",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:up": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-up.ps1",
    "dev:up:unix": "bash ./nix/scripts/dev-up.sh",
    "dev:check": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-check.ps1",
    "dev:check:unix": "bash ./nix/scripts/dev-check.sh",
    "dev:down": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-down.ps1",
    "dev:down:unix": "bash ./nix/scripts/dev-down.sh",
    "dev:state-check": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-state-settling-check.ps1",
    "dev:state-check:unix": "bash ./nix/scripts/dev-state-settling-check.sh",
    "dev:body-config-check:unix": "bash ./nix/scripts/dev-body-config-check.sh",
    "dev:command-capture-check": "powershell -ExecutionPolicy Bypass -File .\\nix\\scripts\\dev-command-capture-check.ps1",
    "dev:command-capture-check:unix": "bash ./nix/scripts/dev-command-capture-check.sh",
    "dev:task-workbench-check:unix": "bash ./nix/scripts/dev-task-workbench-check.sh",
    "dev:task-executor-check:unix": "bash ./nix/scripts/dev-task-executor-check.sh",
    "dev:persistence-check:unix": "bash ./nix/scripts/dev-persistence-check.sh",
    "dev:planner-check:unix": "bash ./nix/scripts/dev-planner-check.sh",
    "dev:operator-loop-check:unix": "bash ./nix/scripts/dev-operator-loop-check.sh",
    "dev:operator-control-check:unix": "bash ./nix/scripts/dev-operator-control-check.sh",
    "dev:policy-check:unix": "bash ./nix/scripts/dev-policy-check.sh",
    "dev:approval-check:unix": "bash ./nix/scripts/dev-approval-check.sh",
    "dev:capability-check:unix": "bash ./nix/scripts/dev-capability-check.sh",
    "dev:event-audit-check:unix": "bash ./nix/scripts/dev-event-audit-check.sh",
    "dev:system-sense-check:unix": "bash ./nix/scripts/dev-system-sense-check.sh",
    "dev:system-heal-check:unix": "bash ./nix/scripts/dev-system-heal-check.sh",
    "dev:observer-operator-check:unix": "bash ./nix/scripts/dev-observer-operator-check.sh",
    "dev:milestone-check:unix": "bash ./nix/scripts/dev-milestone-check.sh"
  }
}
