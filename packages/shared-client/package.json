{
  "name": "@openclaw/shared-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.mjs"
    },
    "./service-descriptors": {
      "types": "./src/service-descriptors.d.ts",
      "default": "./src/service-descriptors.mjs"
    }
  },
  "scripts": {
    "build": "npm run typecheck && npm test",
    "typecheck": "tsc -p tsconfig.json --noEmit && node --check src/service-descriptors.mjs && node --check src/index.mjs",
    "test": "node --test test/*.test.mjs"
  }
}
