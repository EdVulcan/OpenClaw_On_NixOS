{
  "name": "@openclaw/shared-types",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts"
    },
    "./api": {
      "types": "./src/api.ts"
    },
    "./events": {
      "types": "./src/events.ts"
    },
    "./policy": {
      "types": "./src/policy.ts"
    },
    "./plugin-contract": {
      "types": "./src/plugin-contract.ts",
      "default": "./src/plugin-contract.mjs"
    },
    "./plugin-registry": {
      "types": "./src/plugin-registry.ts",
      "default": "./src/plugin-registry.mjs"
    },
    "./screen": {
      "types": "./src/screen.ts"
    },
    "./session": {
      "types": "./src/session.ts"
    },
    "./system": {
      "types": "./src/system.ts"
    },
    "./task": {
      "types": "./src/task.ts"
    }
  },
  "scripts": {
    "build": "npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit && node --check src/plugin-contract.mjs && node --check src/plugin-registry.mjs"
  }
}
